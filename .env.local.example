# Copy to .env.local and fill in your own values.

# Redis connection. Upstash gives you a rediss:// URL on the dashboard.
# Example: rediss://default:PASSWORD@your-name.upstash.io:6379
REDIS_URL=

# AeroDataBox API key (RapidAPI) for the /api/flights/lookup endpoint.
# Sign up at https://rapidapi.com/aedbx-aedbx/api/aerodatabox and use the Basic (free) plan.
AERODATABOX_API_KEY=

# Owner token. Anyone with this token can edit. Anyone without it gets a
# read-only, sanitized view (no confirmation numbers, phones, vendors,
# passenger lists, or addresses). Generate with:
#   node -e "console.log('vp-'+require('crypto').randomBytes(16).toString('hex'))"
# Leave empty for fully open mode (dev only).
OWNER_TOKEN=
